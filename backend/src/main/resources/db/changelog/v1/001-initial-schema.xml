<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
      http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="001-create-users" author="codex">
        <createTable tableName="users">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="display_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="password_hash" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="full_name" type="VARCHAR(255)"/>
            <column name="university" type="VARCHAR(255)"/>
            <column name="course" type="VARCHAR(255)"/>
            <column name="graduation_year" type="VARCHAR(64)"/>
            <column name="skills_json" type="TEXT"/>
            <column name="portfolio_links_json" type="TEXT"/>
            <column name="resume" type="TEXT"/>
            <column name="contacts_json" type="TEXT"/>
            <column name="show_applications" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="show_resume" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="company_id" type="UUID"/>
            <column name="blocked" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-companies" author="codex">
        <createTable tableName="companies">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="industry" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="website" type="VARCHAR(255)"/>
            <column name="linkedin" type="VARCHAR(255)"/>
            <column name="vk" type="VARCHAR(255)"/>
            <column name="telegram" type="VARCHAR(255)"/>
            <column name="verified" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-create-tags" author="codex">
        <createTable tableName="tags">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="category" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="004-create-opportunities" author="codex">
        <createTable tableName="opportunities">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="work_format" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="city" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="address" type="VARCHAR(255)"/>
            <column name="latitude" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="longitude" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="salary_min" type="INT"/>
            <column name="salary_max" type="INT"/>
            <column name="currency" type="VARCHAR(16)"/>
            <column name="published_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="expiry_date" type="DATE"/>
            <column name="event_date" type="DATE"/>
            <column name="contact_email" type="VARCHAR(255)"/>
            <column name="contact_phone" type="VARCHAR(64)"/>
            <column name="contact_website" type="VARCHAR(255)"/>
            <column name="tags_json" type="TEXT"/>
            <column name="status" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="requirements" type="TEXT"/>
            <column name="media_content_json" type="TEXT"/>
        </createTable>
    </changeSet>

    <changeSet id="005-create-applications" author="codex">
        <createTable tableName="applications">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="opportunity_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="applicant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="applied_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="message" type="TEXT"/>
        </createTable>
        <addUniqueConstraint tableName="applications" columnNames="opportunity_id, applicant_id" constraintName="uq_applications_opportunity_applicant"/>
    </changeSet>

    <changeSet id="006-create-favorites" author="codex">
        <createTable tableName="favorites">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="opportunity_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="favorites" columnNames="user_id, opportunity_id" constraintName="uq_favorites_user_opportunity"/>
    </changeSet>
</databaseChangeLog>
