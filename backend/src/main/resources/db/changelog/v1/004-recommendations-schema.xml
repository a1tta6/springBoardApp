<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
      http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="008-create-recommendations" author="Danil">
        <createTable tableName="recommendations">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="referrer_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="referee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="subject_user_id" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="opportunity_id" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="comment" type="VARCHAR(1024)">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
